# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000
# Set to "true" on Render (frontend + backend on different subdomains).
# Leave "false" for local dev (both on localhost).
CROSS_SITE_COOKIES=false

# MongoDB Atlas
# Get this from Atlas -> Connect -> Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/chatapp?retryWrites=true&w=majority

# JWT
JWT_ACCESS_SECRET=change_this_to_a_long_random_string
JWT_REFRESH_SECRET=change_this_to_a_different_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# OTP
OTP_EXPIRES_MINUTES=5
# In development, OTPs are printed to the server console instead of actually
# being emailed/texted. Fill these in and wire up sendOtp.js to go live.

# Email (Nodemailer / SMTP) - used for email OTP delivery in production
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Chat App <no-reply@chatapp.com>"

# SMS (Twilio) - used for mobile OTP delivery in production
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Cloudinary (media uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Rate limiting
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=200
